{
	"expo": {
		"name": "Pay It After",
		"slug": "payitafter",
		"version": "0.1.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "app",
		"userInterfaceStyle": "dark",
		"newArchEnabled": true,
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#2a0d0f",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"package": "pt.miguelmagueijo.payitafter",
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			[
				"expo-sqlite",
				{
					"enableFTS": true,
					"useSQLCipher": false
				}
			],
			[
				"@react-native-community/datetimepicker",
				{
					"android": {
						"datePicker": {
							"textColor": {
								"light": "#2bbee3",
								"dark": "#992be3"
							},
							"colorAccent": {
								"light": "#2bbee3",
								"dark": "#992be3"
							}
						}
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "974f1a3d-db57-4f12-aaec-a3bbfa32eaec"
			}
		},
		"owner": "dev_mm"
	}
}
